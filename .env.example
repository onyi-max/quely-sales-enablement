# Quely Sales Enablement — configuration
# Copy to `.env` and edit. All values have safe defaults for local dev.

# HTTP port
PORT=3000

# Dashboard auth (single shared team password). CHANGE THIS.
DASHBOARD_PASSWORD=quely

# Session cookie signing secret. Set to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string
# Set true only when serving over HTTPS.
COOKIE_SECURE=false

# Where the SQLite database file lives (defaults to ./data/quely.db)
# DB_PATH=./data/quely.db

# Public base URL — used to build absolute prospect links inside rep emails.
APP_BASE_URL=http://localhost:3000

# ── Rep email notifications ────────────────────────────────────────────────
# The rep is emailed on a prospect's FIRST view and on EVERY question.
# Leave SMTP_* unset to run in console-log mode (no real mail sent).
REP_EMAIL=
MAIL_FROM=Quely <no-reply@quely.io>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
